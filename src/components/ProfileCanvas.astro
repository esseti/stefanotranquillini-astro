---
// Reads /public/avatar.jpg, runs Sobel edge detection, animates dots + connections
// Place your photo at public/avatar.jpg before using this component
---

<canvas id="profile-canvas" aria-hidden="true"></canvas>

<script>
  (() => {
    const canvas = document.getElementById('profile-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d', { willReadFrequently: true })!;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    type Pt = { bx: number; by: number; cx: number; cy: number; delay: number; phase: number; speed: number; r: number };
    let points: Pt[] = [];
    let drawStartTime = -1;

    const REVEAL_DUR = 1.1;    // seconds each dot takes to reach position
    const REVEAL_STAGGER = 1.6; // total stagger window

    function easeOutBack(x: number): number {
      const c1 = 1.70158, c3 = c1 + 1;
      return 1 + c3 * Math.pow(x - 1, 3) + c1 * Math.pow(x - 1, 2);
    }

    // ── Sobel edge detection ───────────────────────────────────────
    function sobelEdge(id: ImageData): Float32Array {
      const { data, width, height } = id;
      const out = new Float32Array(width * height);
      const g = (x: number, y: number) => {
        const i = (y * width + x) * 4;
        return 0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2];
      };
      for (let y = 1; y < height - 1; y++) {
        for (let x = 1; x < width - 1; x++) {
          const gx =
            -g(x-1,y-1) + g(x+1,y-1)
            - 2*g(x-1,y) + 2*g(x+1,y)
            - g(x-1,y+1) + g(x+1,y+1);
          const gy =
            -g(x-1,y-1) - 2*g(x,y-1) - g(x+1,y-1)
            + g(x-1,y+1) + 2*g(x,y+1) + g(x+1,y+1);
          out[y * width + x] = Math.hypot(gx, gy);
        }
      }
      return out;
    }

    // ── Load image & compute sample points ────────────────────────
    async function init() {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      await new Promise<void>((res, rej) => {
        img.onload = () => res();
        img.onerror = rej;
        img.src = '/avatar.jpg';
      });

      // Higher res for better interior feature detection
      const SIZE = 420;
      const off = document.createElement('canvas');
      off.width = off.height = SIZE;
      const oc = off.getContext('2d', { willReadFrequently: true })!;

      // Scale to fill square
      const s = Math.max(SIZE / img.naturalWidth, SIZE / img.naturalHeight);
      const sw = img.naturalWidth * s;
      const sh = img.naturalHeight * s;
      oc.drawImage(img, (SIZE - sw) / 2, (SIZE - sh) / 2, sw, sh);

      const edges = sobelEdge(oc.getImageData(0, 0, SIZE, SIZE));

      let maxE = 0;
      for (let i = 0; i < edges.length; i++) if (edges[i] > maxE) maxE = edges[i];

      // Low threshold to catch weak interior features (eyes, beard, lips)
      const thresh = maxE * 0.055;

      // Grid-based spatial sampling: divide into cells, sample from each.
      // This forces uniform spatial coverage — interior face features
      // (weak gradients) get represented alongside the strong silhouette.
      const GRID = 18;
      const PER_CELL = 3;
      const cellW = SIZE / GRID;
      const cellH = SIZE / GRID;
      type Cand = { x: number; y: number; s: number };
      const cells: Cand[][] = Array.from({ length: GRID * GRID }, () => []);

      for (let y = 2; y < SIZE - 2; y++) {
        for (let x = 2; x < SIZE - 2; x++) {
          const e = edges[y * SIZE + x];
          if (e > thresh) {
            const ci = Math.floor(y / cellH) * GRID + Math.floor(x / cellW);
            cells[ci].push({ x: x / SIZE, y: y / SIZE, s: e });
          }
        }
      }

      points = [];
      for (const cell of cells) {
        if (!cell.length) continue;
        cell.sort((a, b) => b.s - a.s);
        const top = cell.slice(0, Math.max(PER_CELL * 4, Math.ceil(cell.length * 0.4)));
        top.sort(() => Math.random() - 0.5);
        const take = Math.min(PER_CELL, top.length);
        for (let i = 0; i < take; i++) {
          points.push({
            bx: top[i].x,
            by: top[i].y,
            cx: 0, cy: 0,          // filled below
            delay: Math.random() * REVEAL_STAGGER,
            phase: Math.random() * Math.PI * 2,
            speed: 0.18 + Math.random() * 0.38,
            r: 1.0 + Math.random() * 0.9,
          });
        }
      }

      // Centroid of all sampled points = reveal origin
      const cx = points.reduce((s, p) => s + p.bx, 0) / points.length;
      const cy = points.reduce((s, p) => s + p.by, 0) / points.length;
      points.forEach(p => { p.cx = cx; p.cy = cy; });
    }

    // ── Resize handler ─────────────────────────────────────────────
    function resize() {
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    // ── Animation loop ─────────────────────────────────────────────
    function draw(t: number) {
      if (drawStartTime < 0) drawStartTime = t;
      const elapsed = t - drawStartTime;

      const W = canvas.offsetWidth;
      const H = canvas.offsetHeight;

      if (W <= 0 || H <= 0) {
        requestAnimationFrame(ts => draw(ts / 1000));
        return;
      }

      ctx.clearRect(0, 0, W, H);

      if (!points.length) {
        requestAnimationFrame(ts => draw(ts / 1000));
        return;
      }

      const figW = W * 0.92;
      const figH = H * 0.92;
      const ox = (W - figW) / 2;
      const oy = (H - figH) / 2;
      const DRIFT = figW * 0.007;
      const CDIST = figW * 0.068;
      const CDIST2 = CDIST * CDIST;

      const pts = points.map(p => {
        // Progress for this dot: 0 → 1 over REVEAL_DUR after its delay
        const raw = Math.min(1, Math.max(0, (elapsed - p.delay) / REVEAL_DUR));
        const ease = raw < 1 ? easeOutBack(raw) : 1;

        // Start = centroid, end = final edge position + drift
        const targetX = ox + (p.bx + Math.sin(t * p.speed + p.phase) * (DRIFT / figW)) * figW;
        const targetY = oy + (p.by + Math.cos(t * p.speed * 1.3 + p.phase) * (DRIFT / figH)) * figH;
        const startX  = ox + p.cx * figW;
        const startY  = oy + p.cy * figH;

        return {
          x: startX + (targetX - startX) * ease,
          y: startY + (targetY - startY) * ease,
          r: p.r,
          a: Math.min(1, raw * 2.5), // fade in opacity faster than position
        };
      });

      // Connections — only between dots that are mostly revealed
      for (let i = 0; i < pts.length; i++) {
        if (pts[i].a < 0.3) continue;
        for (let j = i + 1; j < pts.length; j++) {
          if (pts[j].a < 0.3) continue;
          const dx = pts[i].x - pts[j].x;
          const dy = pts[i].y - pts[j].y;
          const d2 = dx * dx + dy * dy;
          if (d2 < CDIST2) {
            const distAlpha = (1 - Math.sqrt(d2) / CDIST) * 0.28;
            const alpha = distAlpha * Math.min(pts[i].a, pts[j].a);
            ctx.strokeStyle = `rgba(0,255,135,${alpha.toFixed(3)})`;
            ctx.lineWidth = 0.55;
            ctx.beginPath();
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.stroke();
          }
        }
      }

      // Dots
      for (const pt of pts) {
        if (pt.a <= 0) continue;
        const grd = ctx.createRadialGradient(pt.x, pt.y, 0, pt.x, pt.y, pt.r * 3);
        grd.addColorStop(0, `rgba(0,255,135,${(0.55 * pt.a).toFixed(3)})`);
        grd.addColorStop(1, 'rgba(0,255,135,0)');
        ctx.fillStyle = grd;
        ctx.beginPath();
        ctx.arc(pt.x, pt.y, pt.r * 3, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = `rgba(0,255,135,${(0.85 * pt.a).toFixed(3)})`;
        ctx.beginPath();
        ctx.arc(pt.x, pt.y, pt.r, 0, Math.PI * 2);
        ctx.fill();
      }

      requestAnimationFrame(ts => draw(ts / 1000));
    }

    window.addEventListener('resize', () => { resize(); }, { passive: true });
    resize();
    init()
      .then(() => requestAnimationFrame(ts => draw(ts / 1000)))
      .catch(() => {}); // graceful: no image = invisible canvas
  })();
</script>

<style>
  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
