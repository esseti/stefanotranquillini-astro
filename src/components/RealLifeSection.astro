---

<section id="real-life" class="section section--alt">
  <div class="section__inner">
    <div class="section__num">05 / real life</div>
    <h2 class="section__heading">Real Life</h2>
    <div class="divider" />

    <p class="rl__intro prompt">{realLife.intro}</p>

    <div class="rl__interests">
      {realLife.interests.map(item => (
        <div class="rl__interest">
          <span class="rl__icon" aria-hidden="true" set:html={icons[item.icon] ?? ''} />
          <span class="rl__name">{item.name}</span>
        </div>
      ))}
    </div>

    <div class="rl__footer">
      <span class="rl__eof">// EOF</span>
      <span class="cursor" />
      <button class="rl__continua" id="rl-continua" aria-label="continua" hidden>continua_</button>
    </div>
  </div>
</section>

<!-- Banksy full-screen overlay -->
<div class="banksy-overlay" id="banksy-overlay" aria-hidden="true" role="dialog" aria-modal="true">
  <button class="banksy-close" id="banksy-close" aria-label="chiudi">×</button>
  <blockquote class="banksy-quote">
    <p>{realLife.quote}</p>
    <cite>— {realLife.quoteAuthor}</cite>
  </blockquote>
</div>

<script>
  const section = document.getElementById('real-life');
  const trigger = document.getElementById('rl-continua') as HTMLButtonElement;
  const overlay = document.getElementById('banksy-overlay')!;
  const closeBtn = document.getElementById('banksy-close')!;

  let timer: ReturnType<typeof setTimeout> | null = null;
  let revealed = false;

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting && !revealed) {
        timer = setTimeout(() => {
          trigger.hidden = false;
          requestAnimationFrame(() => trigger.classList.add('rl__continua--visible'));
        }, 10000);
      } else {
        if (timer) { clearTimeout(timer); timer = null; }
      }
    },
    { threshold: 0.6 }
  );

  if (section) observer.observe(section);

  trigger.addEventListener('click', () => {
    revealed = true;
    overlay.classList.add('banksy-overlay--open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  });

  function closeOverlay() {
    overlay.classList.remove('banksy-overlay--open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    trigger.focus();
  }

  closeBtn.addEventListener('click', closeOverlay);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeOverlay(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && overlay.classList.contains('banksy-overlay--open')) closeOverlay(); });
</script>

<style>
  .rl__intro {
    margin-bottom: 36px;
    font-size: 14px;
  }

  .rl__interests {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 8px;
    margin-bottom: 48px;
  }

  .rl__interest {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-card);
    cursor: default;
  }

  .rl__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--accent);
    width: 18px;
  }

  .rl__icon svg {
    display: block;
  }

  .rl__name {
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  /* Footer */
  .rl__footer {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .rl__eof {
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  /* Easter egg trigger */
  .rl__continua {
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: 13px;
    color: var(--accent);
    letter-spacing: 0.08em;
    cursor: pointer;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .rl__continua--visible {
    opacity: 1;
    transform: translateX(0);
  }

  .rl__continua:hover {
    text-decoration: underline;
  }

  /* Banksy full-screen overlay */
  .banksy-overlay {
    position: fixed;
    inset: 0;
    background: #c0392b;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .banksy-overlay--open {
    opacity: 1;
    pointer-events: all;
  }

  .banksy-close {
    position: absolute;
    top: 24px;
    right: 32px;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 32px;
    color: #fff;
    cursor: pointer;
    line-height: 1;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .banksy-close:hover {
    opacity: 1;
  }

  .banksy-quote {
    max-width: 720px;
    text-align: center;
  }

  .banksy-quote p {
    font-size: clamp(20px, 4vw, 36px);
    color: #fff;
    font-style: italic;
    line-height: 1.5;
    margin-bottom: 24px;
  }

  .banksy-quote cite {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    font-style: normal;
    letter-spacing: 0.1em;
  }
</style>
