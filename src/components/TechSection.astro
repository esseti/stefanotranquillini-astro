---
import { tech } from '../data/site';
---

<section id="tech" class="section section--alt">
  <div class="section__inner">
    <div class="section__num">03 / tech</div>
    <h2 class="section__heading">Tech</h2>
    <div class="divider" />

    <p class="tech__intro prompt">{tech.intro}</p>

    <div class="tech__grid">
      <div class="tech__skills">
        <div class="label" style="margin-bottom: 20px;">$ skills --list</div>
        <div class="skill-groups">
          {tech.skills.map(group => (
            <div class="skill-group">
              <div class="skill-group__label">// {group.category}</div>
              <div class="skill-group__tags">
                {group.items.map(item => (
                  <span class="tag">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="tech__philosophy">
        <div class="label" style="margin-bottom: 16px;">// architecture</div>
        <div class="tech__card">
          <p>{tech.philosophy}</p>
        </div>

