<style>
  .tech__intro {
    margin-bottom: 40px;
    font-size: 14px;
  }

  .tech__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px 56px;
    align-items: start;
  }

  /* Skill groups */
  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .skill-group__label {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: lowercase;
    margin-bottom: 8px;
  }

  .skill-group__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* Philosophy card */
  .tech__card {
    padding: 18px 20px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg-card);
    border-left: 2px solid var(--accent);
    margin-bottom: 24px;
  }

  .tech__card p {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.75;
    font-style: italic;
  }

  /* ASCII art */
  .tech__ascii {
    overflow: hidden;
  }

  .tech__ascii pre {
    font-size: 10px;
    color: var(--text-muted);
    line-height: 1.5;
    letter-spacing: 0.02em;
    border: 1px solid var(--border);
    padding: 14px;
    background: rgba(0, 255, 135, 0.02);
    border-radius: 2px;
    overflow-x: auto;
  }

  @media (max-width: 640px) {
    .tech__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
