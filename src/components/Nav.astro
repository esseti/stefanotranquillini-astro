---
import { nav, projects } from '../data/site';
---

<header id="nav">
  <div class="nav-inner">
    <a href="#ciao" class="nav-brand" aria-label="Stefano Tranquillini – home">ST_<span class="nav-cursor" /></a>

    <nav class="nav-links" aria-label="Main navigation">
      {nav.map(item => (
        <a
          href={item.href}
          class="nav-link"
          data-section={item.href.replace('#', '')}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav-projects">
      {projects.map(p => (
        <a href={p.href} class="nav-project" target="_blank" rel="noopener">
          {p.label}
        </a>
      ))}
    </div>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav-mobile-menu" id="mobile-menu">
    {nav.map(item => (
      <a href={item.href} class="nav-mobile-link">{item.label}</a>
    ))}
    <div class="nav-mobile-projects">
      {projects.map(p => (
        <a href={p.href} class="nav-project">{p.label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('nav')!;
  const toggle = header.querySelector('.nav-toggle') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const navLinks = header.querySelectorAll('.nav-link');
  const mobileLinks = mobileMenu.querySelectorAll('.nav-mobile-link');

  // Scroll-based header state
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 60) {
      header.classList.add('is-scrolled');
    } else {
      header.classList.remove('is-scrolled');
    }
    lastScroll = y;
  }, { passive: true });

  // Active section tracking
  const sections = document.querySelectorAll<HTMLElement>('section[id]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navLinks.forEach(link => {
          const active = link.getAttribute('data-section') === id;
          link.classList.toggle('is-active', active);
        });
      }
    });
  }, { rootMargin: '-40% 0px -40% 0px', threshold: 0 });

  sections.forEach(s => observer.observe(s));

  // Mobile menu toggle
  toggle.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.classList.toggle('is-open', !open);
    mobileMenu.classList.toggle('is-open', !open);
  });

  // Close mobile menu on link click
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('is-open');
      mobileMenu.classList.remove('is-open');
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    transition: background 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease;
    border-bottom: 1px solid transparent;
  }

  header.is-scrolled {
    background: rgba(8, 11, 18, 0.82);
    backdrop-filter: blur(14px) saturate(1.4);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    border-bottom-color: var(--border);
  }

  .nav-inner {
    max-width: calc(var(--max-w) + 80px);
    margin: 0 auto;
    padding: 0 var(--pad-x);
    height: 100%;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  /* Brand */
  .nav-brand {
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    opacity: 1;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-cursor {
    display: inline-block;
    width: 8px;
    height: 14px;
    background: var(--accent);
    animation: blink 1.2s step-end infinite;
    vertical-align: middle;
    margin-left: 1px;
  }

  /* Main nav links */
  .nav-links {
    display: flex;
    gap: 2px;
    flex: 1;
  }

  .nav-link {
    padding: 5px 11px;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.07em;
    border-radius: 2px;
    transition: color 0.2s;
    position: relative;
    opacity: 1;
  }

  .nav-link::before {
    content: '> ';
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.15s;
  }

  .nav-link:hover {
    color: var(--text-dim);
    opacity: 1;
  }

  .nav-link.is-active {
    color: var(--accent);
    opacity: 1;
  }

  .nav-link.is-active::before {
    opacity: 1;
  }

  /* Project links */
  .nav-projects {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .nav-project {
    padding: 3px 9px;
    font-size: 11px;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 2px;
    letter-spacing: 0.07em;
    transition: color 0.2s, border-color 0.2s;
    opacity: 1;
  }

  .nav-project:hover {
    color: var(--accent);
    border-color: var(--border-hover);
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-muted);
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-toggle.is-open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); background: var(--accent); }
  .nav-toggle.is-open span:nth-child(2) { opacity: 0; }
  .nav-toggle.is-open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); background: var(--accent); }

  /* Mobile dropdown */
  .nav-mobile-menu {
    display: none;
    position: absolute;
    top: var(--nav-h);
    left: 0;
    right: 0;
    background: rgba(8, 11, 18, 0.96);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    padding: 16px var(--pad-x) 20px;
    flex-direction: column;
    gap: 4px;
  }

  .nav-mobile-menu.is-open {
    display: flex;
  }

  .nav-mobile-link {
    padding: 8px 0;
    font-size: 13px;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    letter-spacing: 0.06em;
    opacity: 1;
    transition: color 0.2s;
  }

  .nav-mobile-link:hover { color: var(--accent); }

  .nav-mobile-projects {
    display: flex;
    gap: 8px;
    padding-top: 12px;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .nav-links, .nav-projects { display: none; }
    .nav-toggle { display: flex; }
  }
</style>
