---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080b12" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ─── Design tokens ──────────────────────────────── */
  :root {
    --bg:           #080b12;
    --bg-alt:       #0c1020;
    --bg-card:      #0f1525;
    --accent:       #00ff87;
    --accent-dim:   rgba(0, 255, 135, 0.12);
    --accent-glow:  rgba(0, 255, 135, 0.25);
    --purple:       #9d4edd;
    --purple-dim:   rgba(157, 78, 221, 0.12);
    --coral:        #ff6b6b;
    --text:         #c9d1d9;
    --text-muted:   #8c939e;
    --text-dim:     #8b949e;
    --border:       rgba(0, 255, 135, 0.1);
    --border-hover: rgba(0, 255, 135, 0.35);
    --font:         'JetBrains Mono', monospace;
    --nav-h:        60px;
    --max-w:        860px;
    --pad-x:        40px;
  }

  /* ─── Reset ──────────────────────────────────────── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 14px;
  }

  body {
    font-family: var(--font);
    background-color: var(--bg);
    color: var(--text);
    line-height: 1.75;
    overflow-x: hidden;
  }

  /* Subtle scanline overlay */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.018) 2px,
      rgba(0, 0, 0, 0.018) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* ─── Typography ─────────────────────────────────── */
  h1, h2, h3 {
    font-weight: 700;
    line-height: 1.1;
    color: var(--text);
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  a:hover { opacity: 0.65; }

  ::selection {
    background: var(--accent-dim);
    color: var(--accent);
  }

  /* ─── Shared components ──────────────────────────── */
  .label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .prompt {
    color: var(--text-muted);
    font-size: 13px;
  }

  .prompt::before {
    content: '> ';
    color: var(--accent);
    font-weight: 700;
  }

  .divider {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    margin: 28px 0;
  }

  .tag {
    display: inline-block;
    font-size: 11px;
    padding: 3px 10px;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    transition: border-color 0.2s, color 0.2s;
  }

  .tag:hover {
    border-color: var(--border-hover);
    color: var(--accent);
    opacity: 1;
  }

  /* ─── Animations ─────────────────────────────────── */
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes glitch-a {
    0%        { clip-path: inset(0 0 98% 0); transform: translate(-3px, 0); color: var(--purple); }
    8%        { clip-path: inset(25% 0 55% 0); transform: translate(3px, 0); }
    16%       { clip-path: inset(70% 0 12% 0); transform: translate(-2px, 0); }
    24%, 100% { clip-path: inset(0 0 100% 0); transform: none; }
  }

  @keyframes glitch-b {
    0%        { clip-path: inset(0 0 90% 0); transform: translate(3px, 0); color: var(--coral); }
    12%       { clip-path: inset(45% 0 35% 0); transform: translate(-3px, 0); }
    20%       { clip-path: inset(15% 0 65% 0); transform: translate(2px, 0); }
    28%, 100% { clip-path: inset(0 0 100% 0); transform: none; }
  }

  /* ─── Cursor ─────────────────────────────────────── */
  .cursor {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    background: var(--accent);
    vertical-align: text-bottom;
    animation: blink 1.1s step-end infinite;
    margin-left: 1px;
  }

  /* ─── Section wrapper ────────────────────────────── */
  .section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-h) + 64px) var(--pad-x) 64px;
  }

  .section {
    transition: background 0.7s ease;
  }

  main > section:nth-child(odd).in-view {
    background: radial-gradient(
      ellipse 90% 55% at 50% 0%,
      rgba(0, 255, 135, 0.055) 0%,
      transparent 70%
    );
  }

  main > section:nth-child(even).in-view {
    background: radial-gradient(
      ellipse 90% 55% at 50% 0%,
      rgba(157, 78, 221, 0.055) 0%,
      transparent 70%
    );
  }

  .section__inner {
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
  }

  .section__num {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
    opacity: 0.8;
  }

  .section__heading {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  /* ─── Scrollbar ──────────────────────────────────── */
  ::-webkit-scrollbar       { width: 3px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--accent-dim); border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(0, 255, 135, 0.4); }

  /* ─── Mobile ─────────────────────────────────────── */
  @media (max-width: 640px) {
    :root { --pad-x: 20px; }
    html { font-size: 13px; }
    .section {
      padding-top: calc(var(--nav-h) + 24px);
      padding-bottom: 48px;
      align-items: flex-start;
    }
  }
</style>

<script>
  const sections = document.querySelectorAll('main > section');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add('in-view');
        else e.target.classList.remove('in-view');
      });
    },
    { threshold: 0.15 }
  );
  sections.forEach((s) => observer.observe(s));
</script>
